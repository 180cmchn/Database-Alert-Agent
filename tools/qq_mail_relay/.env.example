# The relay is intentionally dry-run by default. Set false only after verifying
# the recipient and generating a QQ Mail SMTP authorization code.
QQ_MAIL_RELAY_DRY_RUN=true

# Generate a random value of at least 32 characters. Configure the same value as
# MANAGEMENT_WEBHOOK_BEARER_TOKEN in Database Alert Agent webhook mode.
QQ_MAIL_RELAY_BEARER_TOKEN=

QQ_MAIL_RELAY_MAIL_FROM=sender@qq.com
QQ_MAIL_RELAY_MAIL_TO=recipient@qq.com
QQ_MAIL_RELAY_SUBJECT_PREFIX=[Database Alert Agent]
QQ_MAIL_RELAY_DATABASE_PATH=./data/qq-mail-relay.db

QQ_MAIL_RELAY_SMTP_HOST=smtp.qq.com
QQ_MAIL_RELAY_SMTP_PORT=465
QQ_MAIL_RELAY_SMTP_SECURITY=ssl
QQ_MAIL_RELAY_SMTP_USERNAME=sender@qq.com
# Use the QQ Mail SMTP authorization code, never the QQ login password.
QQ_MAIL_RELAY_SMTP_AUTH_CODE=
QQ_MAIL_RELAY_SMTP_TIMEOUT_SECONDS=10
