APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./data/alerts.db

# Real OpenAI-compatible model (OpenAI, DeepSeek, an internal gateway, etc.)
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_JSON_MODE=true

RUNBOOK_DIR=./runbooks
RUNBOOK_LIMIT=5
SEVERITY_MAPPING={"P0":"CRITICAL","P1":"HIGH","P2":"MEDIUM","P3":"LOW","FATAL":"CRITICAL","ERROR":"HIGH","WARN":"MEDIUM","WARNING":"MEDIUM","INFO":"LOW"}
ESCALATION_SEVERITIES=["CRITICAL"]

# Use "log" locally or "webhook" for a real management endpoint.
NOTIFIER_MODE=log
MANAGEMENT_WEBHOOK_URL=
MANAGEMENT_WEBHOOK_BEARER_TOKEN=
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_BACKOFF_SECONDS=0.5

KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ALERT_TOPIC=database-alerts
KAFKA_DLQ_TOPIC=database-alerts.dlq
KAFKA_CONSUMER_GROUP=database-alert-agent
KAFKA_MAX_RETRIES=3
