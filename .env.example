APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./data/alerts.db

# Required for every /api/v1/admin/* write or settings request.
# Generate a long random value; do not reuse the model API key.
ADMIN_API_TOKEN=
RUNTIME_SETTINGS_PATH=./data/runtime-settings.json
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000"]

# Real OpenAI-compatible model (OpenAI, DeepSeek, an internal gateway, etc.)
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_JSON_MODE=true

RUNBOOK_PDF_DIR=./runbooks/pdfs
RUNBOOK_LIMIT=5
# PDFs are loaded directly from this local directory. They must be unencrypted and
# contain a searchable text layer; scanned/image-only files require OCR beforehand.
RUNBOOK_PDF_MAX_FILE_BYTES=20000000
RUNBOOK_PDF_MAX_TEXT_CHARS=200000
ENVIRONMENT_ALIASES={"production":["prod","prd","production","生产","生产环境"],"staging":["staging","pre","预发"],"test":["test","t1","qa","测试"],"development":["dev","development","开发"]}
# The only outbound integration is the Enterprise WeChat group robot. Every completed
# AI analysis (CRITICAL/WARNING/INFO) is sent once; delivery tracking and retries are
# intentionally outside this service. The URL is treated as a credential and never read back.
WECOM_WEBHOOK_URL=

KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ALERT_TOPIC=database-alerts
KAFKA_DLQ_TOPIC=database-alerts.dlq
KAFKA_CONSUMER_GROUP=database-alert-agent
KAFKA_MAX_RETRIES=3

# HTTP accepts quickly and schedules investigation in the background.
# Use in_memory locally, kafka in a multi-process deployment, or manual in tests.
HTTP_SCHEDULER=in_memory
SCHEDULER_WORKERS=1
INVESTIGATION_LEASE_SECONDS=600
TOOL_MAX_RESULT_CHARS=12000

# Enable only after real read-only investigation tools are connected.
REACT_ENABLED=false
REACT_MAX_DYNAMIC_TURNS=2
VALIDATION_ENABLED=true
